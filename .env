# DeerFlow Environment Variables
# LM Studio does not require API keys for the LLM itself.
# However, some tools (web search, web fetch) need their own API keys.

# Tavily API Key (for web search - get free key at https://tavily.com)
TAVILY_API_KEY=your-tavily-api-key

# Jina API Key (for web fetch - get free key at https://jina.ai)
JINA_API_KEY=your-jina-api-key

# InfoQuest API Key
# INFOQUEST_API_KEY=your-infoquest-api-key

# No OpenAI key needed - LM Studio uses "lm-studio" as dummy key
# OPENAI_API_KEY is NOT required
