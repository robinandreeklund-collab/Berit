# TAVILY API Key
TAVILY_API_KEY=your-tavily-api-key

# Jina API Key
JINA_API_KEY=your-jina-api-key

# InfoQuest API Key
INFOQUEST_API_KEY=your-infoquest-api-key
# CORS Origins (comma-separated) - e.g., http://localhost:3000,http://localhost:3001
# CORS_ORIGINS=http://localhost:3000

# Optional:
# FIRECRAWL_API_KEY=your-firecrawl-api-key
# VOLCENGINE_API_KEY=your-volcengine-api-key
# OPENAI_API_KEY=your-openai-api-key
# GEMINI_API_KEY=your-gemini-api-key
# DEEPSEEK_API_KEY=your-deepseek-api-key
# NOVITA_API_KEY=your-novita-api-key  # OpenAI-compatible, see https://novita.ai
# FEISHU_APP_ID=your-feishu-app-id
# FEISHU_APP_SECRET=your-feishu-app-secret

# SLACK_BOT_TOKEN=your-slack-bot-token
# SLACK_APP_TOKEN=your-slack-app-token
# TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# SCB MCP Server URL (Swedish official statistics)
# Docker: http://scb-mcp:3000/mcp (automatic)
# Render fallback: https://scb-mcp.onrender.com/mcp
# SCB_MCP_URL=https://scb-mcp.onrender.com/mcp

# Skolverket MCP Server URL (Swedish education data)
# Docker: http://skolverket-mcp:3000/mcp (automatic)
# Combined Render instance (same host as SCB, /skolverket/ prefix):
# SKOLVERKET_MCP_URL=https://scb-mcp.onrender.com/skolverket/mcp

# Trafikverket MCP Server URL (Swedish traffic data)
# Docker: http://trafikverket-mcp:3000/mcp (automatic)
# Combined Render instance (same host as SCB, /trafikverket/ prefix):
# TRAFIKVERKET_MCP_URL=https://scb-mcp.onrender.com/trafikverket/mcp
# TRAFIKVERKET_API_KEY=your-trafikverket-api-key

# Riksbank MCP Server URL (Swedish economic data)
# Docker: http://riksbank-mcp:3000/mcp (automatic)
# Combined Render instance (same host as SCB, /riksbank/ prefix):
# RIKSBANK_MCP_URL=https://scb-mcp.onrender.com/riksbank/mcp
# RIKSBANK_API_KEY=your-riksbank-api-key

# SMHI MCP Server URL (Swedish weather, hydrology, oceanography, fire risk)
# Docker: http://smhi-mcp:3000/mcp (automatic)
# Combined Render instance (same host as SCB, /smhi/ prefix):
# SMHI_MCP_URL=https://scb-mcp.onrender.com/smhi/mcp

# Lightpanda MCP Server URL (web browsing, search, data extraction)
# IMPORTANT: This replaces the old community tools (web_search/web_fetch in config.yaml).
# All web browsing is now handled by the Lightpanda MCP server.
# Lightpanda runs LOCAL ONLY (not on Render) — requires headless browser sidecar.
# `make dev` starts both browser and MCP server automatically.
# Docker Compose: http://lightpanda-mcp:3000/mcp (automatic)
# Leave commented out for local auto-start:
# LIGHTPANDA_MCP_URL=http://localhost:3105/mcp

# Elpris MCP Server URL (Swedish electricity prices)
# Docker: http://elpris-mcp:3000/mcp (automatic)
# Combined Render instance (same host as SCB, /elpris/ prefix):
# ELPRIS_MCP_URL=https://scb-mcp.onrender.com/elpris/mcp

# Bolagsverket MCP Server URL (Swedish company data)
# Docker: http://bolagsverket-mcp:3000/mcp (automatic)
# Combined Render instance (same host as SCB, /bolagsverket/ prefix):
# BOLAGSVERKET_MCP_URL=https://scb-mcp.onrender.com/bolagsverket/mcp
# BOLAGSVERKET_CLIENT_ID=your-bolagsverket-client-id
# BOLAGSVERKET_CLIENT_SECRET=your-bolagsverket-client-secret

# Google Maps MCP Server URL (geocoding, places, directions)
# Docker: http://google-maps-mcp:3000/mcp (automatic)
