{
  "name": "lightpanda-mcp",
  "version": "1.0.0",
  "description": "MCP server for Lightpanda headless browser — 12 tools: navigate, search, markdown, links, click, execute_js, fill_form, extract_data, fetch_api, wait_for, get_text, screenshot",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/http-server.js",
    "start:stdio": "node dist/index.js",
    "dev": "tsc --watch",
    "prepare": "npm run build",
    "test": "vitest"
  },
  "keywords": [
    "mcp",
    "lightpanda",
    "headless-browser",
    "cdp",
    "web-fetch",
    "web-search",
    "scraping",
    "claude"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "cors": "^2.8.5",
    "express": "^4.22.1",
    "turndown": "^7.2.0",
    "ws": "^8.18.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "@types/turndown": "^5.0.5",
    "@types/ws": "^8.5.13",
    "typescript": "^5.3.0",
    "vitest": "^4.0.14"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
