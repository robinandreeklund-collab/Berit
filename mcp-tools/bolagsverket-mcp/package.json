{
  "name": "bolagsverket-mcp",
  "version": "1.0.0",
  "description": "MCP server for Bolagsverket Värdefulla datamängder API — 6 tools: organisationsuppslag, grunddata, styrelse, registrering, dokumentlista, dokument",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/http-server.js",
    "start:streamable": "node dist/http-server.js",
    "start:stdio": "node dist/index.js",
    "dev": "tsc --watch",
    "prepare": "npm run build",
    "test": "vitest"
  },
  "keywords": [
    "mcp",
    "bolagsverket",
    "sweden",
    "companies",
    "organizations",
    "claude"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "cors": "^2.8.5",
    "express": "^4.22.1",
    "marked": "^17.0.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0",
    "vitest": "^4.0.14"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
